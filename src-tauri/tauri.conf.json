{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Checkpoint",
    "version":  "1.0.2",
    "identifier":  "app.checkpoint.desktop",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "Checkpoint",
                                    "width":  1100,
                                    "height":  720,
                                    "minWidth":  800,
                                    "minHeight":  500,
                                    "decorations":  true,
                                    "resizable":  false
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "createUpdaterArtifacts":  true,
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgwMTRGNUI5MTAwOTNBQUEKUldTcU9na1F1ZlVVZ0FzZ2lBNFJNZ2lnMkFTSGtVMEpBZlVKZjlOUm9hWXFmUUlLQ1prbkRxVWIK",
                                    "endpoints":  [
                                                      "https://gitee.com/Zhang-Dongfang/Checkpoint/raw/main/latest.json",
                                                      "https://cdn.jsdelivr.net/gh/Zhang-Dongfang/Checkpoint@main/latest.json",
                                                      "https://raw.githubusercontent.com/Zhang-Dongfang/Checkpoint/main/latest.json"
                                                  ]
                                }
                }
}